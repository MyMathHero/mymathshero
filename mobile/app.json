{
  "expo": {
    "name": "MyMathsHero",
    "slug": "mymathshero",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mymathshero.app",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1B2B4B"
      },
      "package": "com.mymathshero.app",
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1B2B4B"
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-asset",
      "expo-sharing"
    ],
    "scheme": "mymathshero",
    "extra": {
      "apiUrl": "https://mymathshero.com.au",
      "eas": {
        "projectId": "ab34858b-08fc-4a7e-a184-a01e1fa196f9"
      }
    }
  }
}
