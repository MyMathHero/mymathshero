{
  "version": 2,
  "regions": ["syd1"],
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_BASE_URL": "https://mymathshero.com.au"
  },
  "crons": [
    { "path": "/api/cron/weekly-reports",  "schedule": "0 22 * * 0" },
    { "path": "/api/cron/streak-reminders", "schedule": "0 7 * * *" },
    { "path": "/api/cron/skill-decay",      "schedule": "0 2 * * *" },
    { "path": "/api/cron/verify-bank",      "schedule": "0 3 1,15 * *" }
  ]
}
