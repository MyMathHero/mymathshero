# Copy these to Vercel Dashboard → Settings → Environment Variables
# (This is a reference template — do NOT put real secret values in this file.)

# --- Currently used by the app (present in .env.local) ---
MONGODB_URI=your_mongodb_connection_string
DB_NAME=mymathshero
OPENROUTER_API_KEY=your_openrouter_key
JWT_SECRET=your_jwt_secret
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=https://mymathshero.com.au
NEXT_PUBLIC_BASE_URL=https://mymathshero.com.au
CORS_ORIGINS=https://mymathshero.com.au

# --- Needed in production if email / payments are enabled ---
# (Routes exist in the app; add real keys before relying on these features.)
RESEND_API_KEY=your_resend_key
STRIPE_SECRET_KEY=your_stripe_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
